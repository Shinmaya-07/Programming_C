//Given a string,s, consisting of alphabets and digits, find the frequency of each digit in the given string.
#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {

    char str[1000];
    int i, n, j;
    scanf("%[^\n]s", str);    
    n = strlen(str);  
  char num = '0';
  for (i=0;i<10;i++){
      int count =0;
      for (j=0;j<n;j++){
            if (str[j] == num){
              count++;
            }
          }
          printf("%d ",count);
          num++;
    }   
    return 0;
}
