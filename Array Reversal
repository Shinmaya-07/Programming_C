
#include <stdio.h>
#include <stdlib.h>

void reverseArray(int arr[], int n) {
    int start = 0;
    int end = n - 1;
    int temp;
    while (start < end) {
        temp = arr[start];
        arr[start] = arr[end];
        arr[end] = temp;
        start++;
        end--;
    }
}

int main()
{
    int num, *arr, i;
    scanf("%d", &num);
    arr = (int*) malloc(num * sizeof(int));
    for(i = 0; i < num; i++) {
        scanf("%d", arr + i);
    }
    reverseArray(arr,num);
    for(i = 0; i < num; i++)
        printf("%d ", *(arr + i));
    return 0;
}
